#!/bin/bash

fmt() {
  printf "%s%3d%s" "$1" "$2" "$3"
}

# CPU usage
cpu=$(awk -v RS="" '{u=$2+$4; t=$2+$4+$5; printf "%.0f", u/t*100}' /proc/stat)

# RAM usage
ram=$(free | awk '/Mem:/ {printf "%.0f", $3/$2*100}')

# Disk usage
disk=$(df /mnt/DATA | awk 'NR==2 {printf "%.0f", $5}' | tr -d '%')

# Battery info
bat_path="/sys/class/power_supply/BAT1"
if [ -d "$bat_path" ]; then
  bat=$(awk '{printf "%.0f", $1*100/$(NF)}' <(paste "$bat_path/energy_now" "$bat_path/energy_full"))
  charging=$(cat "$bat_path/status")
  power_now=$(cat "$bat_path/power_now" 2>/dev/null)
else
  bat=""
  charging=""
  power_now=""
fi

# Build parts array
parts=(
  "$(fmt "ο£Φ " "$cpu" "%")"
  "$(fmt "νΩÖ " "$ram" "%")"
  "$(fmt "σΑ΄ä " "$disk" "%")"
)

# Battery icon
if [ -n "$bat" ]; then
  if [ "$charging" != "Discharging" ]; then
    icon="σΑ²³ "
  else
    icons=("σΑ¹Μ " "σΑ¹Μ " "σΑ¹Φ " "σΑ¹Ϋ " "σΑ¹Ψ " "σΑ¹Ω " "σΑ²Ä " "σΑ²Ä " "σΑ²² " "σΑ¹Ι ")
    index=$(((bat - 1) / 10))
    icon="${icons[index]}"
  fi
  parts+=("$(fmt "$icon" "$bat" "%")")
fi

# Add power_now if available
if [ -n "$power_now" ]; then
  power_now=$((power_now / 1000000))
  parts+=("$(fmt "σ±ê΄" "$power_now" "W")")
fi

# Print joined parts
for ((i = 0; i < ${#parts[@]}; i++)); do
  printf "%s" "${parts[i]}"
  if ((i < ${#parts[@]} - 1)); then
    printf " | "
  fi
done
printf "\n"
